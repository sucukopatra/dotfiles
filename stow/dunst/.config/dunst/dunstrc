[global]
font = JetBrainsMono Nerd Font 10
corner_radius = 8
frame_width = 1
gap_size = 10
padding = 10
horizontal_padding = 12
separator_height = 1
line_height = 2
markup = full
format = "<b>%s</b>\n%b"
alignment = left
vertical_alignment = center
icon_position = left
min_icon_size = 20
max_icon_size = 32
transparency = 5

follow = mouse

notification_limit = 10
indicate_hidden = yes
sort = yes
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
sticky_history = yes
history_length = 20

progress_bar = true

separator_color = auto
ellipsize = middle

mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all

[urgency_low]
background = "#1e1e1e"
foreground = "#dddddd"
frame_color = "#3a3a3a"
timeout = 3

[urgency_normal]
background = "#1e1e1e"
foreground = "#eeeeee"
frame_color = "#5a5a5a"
timeout = 5

[urgency_critical]
background = "#1e1e1e"
foreground = "#ffffff"
frame_color = "#aaaaaa"
timeout = 0
